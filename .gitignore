# pyenv
#   For a library or package, you might want to ignore these files since the user is
#   responsible for setting their own version. For an app, this might be useful.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or experience
#   issues with locking, lock files may be ignored.
#   Pipfile.lock

# poetry
#   According to poetry guidelines, poetry.lock should be committed to VCS.
#   But if poetry.lock is ignored, it will be auto-generated during install.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, PDM recommends committing pdm.lock in version control.
# pdm.lock
#   pdm build stage
.pdm-plugins/

# celry beat schedule file
celerybeat-schedule

